{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and epic settings",
      "type": "object",
      "properties": {
        "epic": { "type": "string", "maxLength": 1000 },
        "epicDeadline": { "type": "string" },
        "age": { "type": "string" },
        "gender": { "type": "string" },
        "weight": { "type": "string" },
        "injuries": { "type": "string", "maxLength": 1000 },
        "sprintLength": { "type": "number", "minimum": 1, "maximum": 30 },
        "currentSprintNum": { "type": "number" },
        "isEpicSet": { "type": "boolean" },
        "email": { "type": "string" }
      }
    },
    "Workout": {
      "title": "Workout",
      "description": "A single workout task",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 200 },
        "type": { "type": "string", "maxLength": 100 },
        "duration": { "type": "number" },
        "description": { "type": "string", "maxLength": 2000 },
        "status": { "type": "string", "enum": ["backlog", "sprint", "done", "missed"] },
        "assignedDay": { "type": "string", "maxLength": 100 },
        "sprintNumber": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["title", "type", "duration", "description", "status", "ownerId"]
    },
    "SprintHistory": {
      "title": "SprintHistory",
      "description": "History record for a sprint iteration",
      "type": "object",
      "properties": {
        "sprintNumber": { "type": "number" },
        "completedWorkouts": { "type": "number" },
        "totalWorkouts": { "type": "number" },
        "velocityScore": { "type": "number" },
        "insights": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ownerId": { "type": "string" }
      },
      "required": ["sprintNumber", "completedWorkouts", "totalWorkouts", "velocityScore", "insights", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile with their epic config"
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": { "$ref": "#/entities/Workout" },
      "description": "User's workouts"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/SprintHistory" },
      "description": "User's sprint history logs"
    }
  }
}
