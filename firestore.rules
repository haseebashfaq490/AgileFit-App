rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { 
      return request.auth != null; 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    function isValidUser() {
      let data = incoming();
      return data.keys().size() >= 1
             && (!('epic' in data) || (data.epic is string && data.epic.size() <= 1000))
             && (!('epicDeadline' in data) || data.epicDeadline is string)
             && (!('age' in data) || data.age is string)
             && (!('gender' in data) || data.gender is string)
             && (!('weight' in data) || data.weight is string)
             && (!('injuries' in data) || (data.injuries is string && data.injuries.size() <= 1000))
             && (!('sprintLength' in data) || data.sprintLength is number)
             && (!('currentSprintNum' in data) || data.currentSprintNum is number)
             && (!('isEpicSet' in data) || data.isEpicSet is bool)
             && (!('email' in data) || data.email is string);
    }

    function isValidWorkout() {
      let data = incoming();
      return data.title is string && data.title.size() <= 200
             && data.type is string && data.type.size() <= 100
             && data.duration is number
             && data.description is string && data.description.size() <= 2000
             && data.status is string && data.status in ["backlog", "sprint", "done", "missed"]
             && (!('assignedDay' in data) || (data.assignedDay is string && data.assignedDay.size() <= 100))
             && (!('sprintNumber' in data) || data.sprintNumber is number)
             && data.ownerId is string
             && data.ownerId == request.auth.uid;
    }

    function isValidSprintHistory() {
      let data = incoming();
      return data.sprintNumber is number
             && data.completedWorkouts is number
             && data.totalWorkouts is number
             && data.velocityScore is number
             && data.insights is list && data.insights.size() <= 10
             && data.ownerId is string
             && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser();
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/workouts/{workoutId} {
      allow get, list: if isSignedIn() && request.auth.uid == userId && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidWorkout();
      allow update: if isSignedIn() && request.auth.uid == userId && isValidWorkout() && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/history/{historyId} {
      allow get, list: if isSignedIn() && request.auth.uid == userId && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidSprintHistory();
      allow update: if isSignedIn() && request.auth.uid == userId && isValidSprintHistory() && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
